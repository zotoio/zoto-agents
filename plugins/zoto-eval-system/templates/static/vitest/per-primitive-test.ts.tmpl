import { existsSync, readFileSync } from "node:fs";
import { resolve } from "node:path";

import { describe, expect, it } from "vitest";

interface AnalyserCaseFixtureFile {
  path: string;
  content?: string;
  from?: string;
}

interface AnalyserCaseFixtures {
  files: AnalyserCaseFixtureFile[];
}

interface AnalyserCaseExpectedFilesystem {
  created?: string[];
  modified?: string[];
  removed?: string[];
  unchanged?: string[];
}

interface AnalyserCase {
  scenario: string;
  prompt: string;
  assertions: string[];
  follow_ups?: string[];
  fixtures?: AnalyserCaseFixtures;
  fixture_justifications?: string[];
  expected_filesystem?: AnalyserCaseExpectedFilesystem;
  expected_output?: string;
}

interface AnalyserPayload {
  schema_version: 1;
  analyser_version: string;
  model_id: string;
  target_id: string;
  kind: "command" | "agent" | "hook" | "skill" | "rule";
  source_path: string;
  source_hash: string;
  summary: string;
  cases: AnalyserCase[];
}

const PAYLOAD: AnalyserPayload = {{PAYLOAD_JSON}};

const SOURCE_PATH = "{{SOURCE_PATH}}";

/**
 * Source-loading helper. Reads the primitive's markdown into the test
 * scope so behavioural assertions can grep against the live source. The
 * lookup walks up from `process.cwd()` (the host repo) and prefers an
 * env-var override (`ZOTO_EVAL_REPO_ROOT`) for nested executions.
 */
function loadPrimitiveSource(): string | null {
  const root = process.env.ZOTO_EVAL_REPO_ROOT ?? process.cwd();
  const abs = resolve(root, SOURCE_PATH);
  if (!existsSync(abs)) return null;
  return readFileSync(abs, "utf-8");
}

const SOURCE_TEXT = loadPrimitiveSource();

describe("{{TARGET_ID}}", () => {
  it("payload schema_version is 1", () => {
    expect(PAYLOAD.schema_version).toBe(1);
  });

  it("payload target_id matches the stamped primitive", () => {
    expect(PAYLOAD.target_id).toBe("{{TARGET_ID}}");
  });

  it("payload source_hash is a sha256 hex digest", () => {
    expect(PAYLOAD.source_hash).toMatch(/^[a-f0-9]{64}$/);
  });

  it("payload contains at least one analyser case", () => {
    expect(PAYLOAD.cases.length).toBeGreaterThan(0);
  });

  it("primitive markdown loads from disk", () => {
    if (SOURCE_TEXT === null) {
      /* The source file is allowed to be missing in unusual sandbox
       * setups (e.g. when the stamper output is copied into an isolated
       * tmp dir without the primitive). Skip gracefully so the per-case
       * behavioural assertions can still run. */
      return;
    }
    expect(typeof SOURCE_TEXT).toBe("string");
    expect(SOURCE_TEXT.length).toBeGreaterThan(0);
  });

  PAYLOAD.cases.forEach((analyserCase, idx) => {
    describe(`case ${idx + 1}: ${analyserCase.scenario}`, () => {
      it("has a non-empty prompt", () => {
        expect(typeof analyserCase.prompt).toBe("string");
        expect(analyserCase.prompt.length).toBeGreaterThan(0);
      });

      it("declares at least one behavioural assertion", () => {
        expect(Array.isArray(analyserCase.assertions)).toBe(true);
        expect(analyserCase.assertions.length).toBeGreaterThan(0);
      });

      analyserCase.assertions.forEach((assertion, aIdx) => {
        const label = `assertion #${aIdx + 1}: ${assertion.slice(0, 60)}`;
        it(label, () => {
          expect(typeof assertion).toBe("string");
          expect(assertion.trim().length).toBeGreaterThan(0);
        });
      });

      if (analyserCase.follow_ups) {
        it("follow-ups are an array of non-empty strings", () => {
          expect(Array.isArray(analyserCase.follow_ups)).toBe(true);
          for (const turn of analyserCase.follow_ups!) {
            expect(typeof turn).toBe("string");
            expect(turn.trim().length).toBeGreaterThan(0);
          }
        });
      }

      if (analyserCase.fixtures) {
        it("fixtures.files is an array", () => {
          expect(Array.isArray(analyserCase.fixtures!.files)).toBe(true);
        });

        analyserCase.fixtures.files.forEach((file, fIdx) => {
          it(`fixture #${fIdx + 1} declares a sandbox-relative path: ${file.path}`, () => {
            expect(typeof file.path).toBe("string");
            expect(file.path.length).toBeGreaterThan(0);
            expect(file.path.startsWith("/")).toBe(false);
            expect(file.path.includes("..")).toBe(false);
          });
        });
      }

      if (analyserCase.expected_filesystem) {
        it("expected_filesystem entries are arrays of non-empty strings", () => {
          const fs = analyserCase.expected_filesystem!;
          for (const key of ["created", "modified", "removed", "unchanged"] as const) {
            const arr = fs[key];
            if (arr === undefined) continue;
            expect(Array.isArray(arr)).toBe(true);
            for (const path of arr) {
              expect(typeof path).toBe("string");
              expect(path.length).toBeGreaterThan(0);
            }
          }
        });
      }

      if (typeof analyserCase.expected_output === "string") {
        it("expected_output is a non-empty string", () => {
          expect(analyserCase.expected_output!.length).toBeGreaterThan(0);
        });
      }
    });
  });
});
