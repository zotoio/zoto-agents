"""Static-backend YAML reporter for the eval-system.

Stamped by ``zoto-eval-system/templates/static/pytest/_reporter.py.tmpl``
and imported by the user-extensible ``conftest.py`` (subtask 06).
Centralises the ``result.schema.json`` contract so the conftest stays
small and the schema shape lives in one place.

Output: ``<runs_dir>/<run_id>/static.yml`` matching
``plugins/zoto-eval-system/templates/schema/result.schema.json`` with
``backend: "static"``. The pytest backend has no LLM tokens so
``aggregates.tokens_total`` is always ``0``; ``duration_ms_total`` is
the sum of per-case durations the conftest captured via
``pytest_runtest_logreport``.

The conftest is the only intended caller; it imports ``CaseRecord``,
``GraderReport`` and ``write_static_report`` from this module.
"""

from __future__ import annotations

from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, List, Literal, Optional

import yaml


__all__ = [
    "CaseRecord",
    "GraderReport",
    "build_static_payload",
    "write_static_report",
    "iso_utc",
    "run_id_from",
]


CaseStatus = Literal["passed", "failed", "skipped", "errored"]
GraderVerdict = Literal["pass", "fail", "warn"]


@dataclass
class GraderReport:
    """Single grader report attached to a case (mirrors result.schema.json)."""

    grader: str
    verdict: str
    detail: str = ""


@dataclass
class CaseRecord:
    """Per-case row matching ``result.schema.json#cases[]``."""

    id: str
    status: str
    duration_ms: int = 0
    grader_reports: List[GraderReport] = field(default_factory=list)


def iso_utc(dt: datetime) -> str:
    """RFC3339-style UTC timestamp with trailing ``Z``."""
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def run_id_from(started_at: datetime) -> str:
    """Deterministic per-run directory name (``YYYYMMDDTHHMMSSZ``)."""
    if started_at.tzinfo is None:
        started_at = started_at.replace(tzinfo=timezone.utc)
    return started_at.astimezone(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def build_static_payload(
    *,
    started_at: datetime,
    ended_at: datetime,
    cases: List[CaseRecord],
    run_id: Optional[str] = None,
    model: Optional[str] = None,
    framework: Optional[str] = None,
) -> dict[str, Any]:
    """Assemble the result.schema.json-compliant dict for one session.

    `framework` is included as additive metadata (the schema permits
    ``additionalProperties``) so consumers can tell which static
    framework produced the file. `model` records the LLM the
    orchestrator was running against - empty for raw pytest invocations.
    """
    rid = run_id or run_id_from(started_at)
    duration_ms_total = 0
    for c in cases:
        try:
            duration_ms_total += int(c.duration_ms or 0)
        except (TypeError, ValueError):
            pass

    payload: dict[str, Any] = {
        "schema_version": 1,
        "run_id": rid,
        "started_at": iso_utc(started_at),
        "ended_at": iso_utc(ended_at),
        "backend": "static",
        "totals": {
            "cases": len(cases),
            "passed": sum(1 for c in cases if c.status == "passed"),
            "failed": sum(1 for c in cases if c.status == "failed"),
            "skipped": sum(1 for c in cases if c.status == "skipped"),
        },
        "aggregates": {
            "tokens_total": 0,
            "duration_ms_total": duration_ms_total,
        },
        "cases": [
            {
                "id": c.id,
                "status": c.status,
                "duration_ms": int(c.duration_ms or 0),
                "grader_reports": [
                    {
                        "grader": g.grader,
                        "verdict": g.verdict,
                        "detail": g.detail or "",
                    }
                    for g in c.grader_reports
                ],
            }
            for c in cases
        ],
    }
    if model:
        payload["model"] = model
    if framework:
        payload["framework"] = framework
    return payload


def write_static_report(
    *,
    runs_dir: Path,
    started_at: datetime,
    ended_at: datetime,
    cases: List[CaseRecord],
    framework: str = "pytest",
    model: Optional[str] = None,
    run_id: Optional[str] = None,
) -> Path:
    """Write a result.schema.json-compliant ``static.yml`` for a session.

    Returns the absolute path to the written file. Creates the
    ``<runs_dir>/<run_id>/`` directory if missing.
    """
    rid = run_id or run_id_from(started_at)
    out_dir = runs_dir / rid
    out_dir.mkdir(parents=True, exist_ok=True)
    payload = build_static_payload(
        started_at=started_at,
        ended_at=ended_at,
        cases=cases,
        run_id=rid,
        model=model,
        framework=framework,
    )
    out_path = out_dir / "static.yml"
    out_path.write_text(
        yaml.safe_dump(payload, sort_keys=True, default_flow_style=False),
        encoding="utf-8",
    )
    return out_path
