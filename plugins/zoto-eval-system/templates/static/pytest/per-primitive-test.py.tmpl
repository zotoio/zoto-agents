@pytest.mark.parametrize(
    "case_idx,file_idx,case,file",
    _fixture_params(),
    ids=[
        f"{_case_id(ci, c.get('scenario') or '')}-fixture-{fi + 1:02d}"
        for ci, fi, c, _ in _fixture_params()
    ],
)
def test_case_fixture_paths_are_safe(
    case_idx: int,
    file_idx: int,
    case: dict[str, Any],
    file: dict[str, Any],
) -> None:
    """Fixture overlay paths obey the analyser schema's safety rules.

    Forbidden: absolute paths, ``..`` segments, env-var expansions,
    backslashes. The runtime sandbox layer (subtask 05) re-validates,
    but failing fast in the static suite catches analyser regressions
    before any LLM call is made.
    """
    path = file.get("path")
    assert isinstance(path, str) and path.strip(), (
        f"fixture #{file_idx + 1} in case #{case_idx + 1} has empty path"
    )
    assert not path.startswith("/"), (
        f"fixture path {path!r} is absolute (forbidden by analyser schema)"
    )
    assert "\\" not in path, (
        f"fixture path {path!r} contains backslash (POSIX-only paths required)"
    )
    assert ".." not in path.split("/"), (
        f"fixture path {path!r} contains '..' segment (escape forbidden)"
    )
    assert "$" not in path, (
        f"fixture path {path!r} contains '$' (env-var expansions forbidden)"
    )
    has_content = isinstance(file.get("content"), str)
    has_from = isinstance(file.get("from_"), str) or isinstance(file.get("from"), str)
    assert has_content or has_from, (
        f"fixture #{file_idx + 1} in case #{case_idx + 1} must declare "
        f"either 'content' or 'from'"
    )


