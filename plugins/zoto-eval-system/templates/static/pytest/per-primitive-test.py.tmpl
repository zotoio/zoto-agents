def test_case_prompt_is_realistic(case_idx: int, case: dict[str, Any]) -> None:
    """Case prompt is a non-empty, non-placeholder string (analyser contract)."""
    prompt = case.get("prompt") or ""
    assert isinstance(prompt, str) and prompt.strip(), (
        f"case #{case_idx + 1} ({case.get('scenario')!r}) has empty prompt"
    )
    assert not PLACEHOLDER_PATTERN.search(prompt), (
        f"case #{case_idx + 1} ({case.get('scenario')!r}) prompt contains "
        f"placeholder vocabulary forbidden by the analyser schema"
    )
    if KIND == "command":
        assert "/" in prompt, (
            f"command case #{case_idx + 1} prompt should mention a /command "
            f"invocation; got: {prompt[:80]!r}"
        )


