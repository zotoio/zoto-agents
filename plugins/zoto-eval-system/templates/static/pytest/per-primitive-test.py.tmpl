@pytest.mark.parametrize(
    "assertion_idx,scenario,assertion,needles",
    ASSERTION_TABLE,
    ids=[_assertion_id(row) for row in ASSERTION_TABLE],
)
def test_case_assertion_is_grounded_in_source(
    assertion_idx: int,
    scenario: str,
    assertion: str,
    needles: list[str],
) -> None:
    """Every analyser assertion references the primitive's documented intent.

    Implements the subtask 06 contract: ``for each behavioural assertion
    in the analyser payload, an assert statement that checks the
    documented intent (e.g. for a skill: ``assert "askQuestion" in
    skill_body`` if the analyser identified askQuestion as a documented
    capability).``

    The TS stamper extracts concrete tokens (``needles``) from each
    assertion. We assert each needle either:

    * appears in the primitive source body (strong grounding), OR
    * the assertion is substantive (>20 chars) and free of vague
      vocabulary. Some assertions reference runtime behaviour absent
      from the source markdown, which is legitimate.
    """
    assert isinstance(assertion, str) and assertion.strip(), (
        f"assertion #{assertion_idx} ({scenario!r}) is empty"
    )
    forbidden = VAGUE_VOCAB_PATTERN.search(assertion)
    assert not forbidden, (
        f"assertion #{assertion_idx} ({scenario!r}) uses vague vocabulary "
        f"forbidden by the analyser schema: {assertion!r}"
    )
    if needles:
        source = _load_source()
        grounded = any(needle in source for needle in needles)
        if not grounded:
            assert len(assertion) > 20, (
                f"assertion #{assertion_idx} ({scenario!r}) is not grounded "
                f"in the source (none of needles={needles!r} present) and is "
                f"too short to be substantive: {assertion!r}"
            )
    else:
        assert len(assertion) > 20, (
            f"assertion #{assertion_idx} ({scenario!r}) has no concrete "
            f"tokens for grounding and is too short to be substantive: "
            f"{assertion!r}"
        )


