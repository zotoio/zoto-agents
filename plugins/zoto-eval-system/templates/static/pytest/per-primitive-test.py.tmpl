def _frontmatter(text: str) -> dict[str, str]:
    """Lightweight YAML-ish frontmatter parser.

    Mirrors ``plugins/zoto-eval-system/scripts/eval-discover.ts#parseFrontmatter`` so the static
    test agrees with the discoverer on what counts as a primitive's
    public surface.
    """
    m = re.match(r"^---\n([\s\S]*?)\n---", text)
    if not m:
        return {}
    out: dict[str, str] = {}
    for line in m.group(1).split("\n"):
        idx = line.find(":")
        if idx == -1:
            continue
        out[line[:idx].strip()] = line[idx + 1 :].strip()
    return out


def _load_source() -> str:
    abs_path = REPO_ROOT / SOURCE_PATH
    if not abs_path.is_file():
        raise FileNotFoundError(
            f"primitive source missing: {SOURCE_PATH} - re-run /z-eval-create"
        )
    return abs_path.read_text(encoding="utf-8")


