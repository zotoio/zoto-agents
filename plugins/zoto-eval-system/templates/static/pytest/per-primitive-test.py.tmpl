# Each row: ``(assertion_idx, scenario, assertion_text, [needles])``.
# The TS stamper precomputes ``needles`` (concrete tokens extracted from
# the assertion) so the Python side performs a fast O(needle) substring
# scan against the primitive source. The ``needles`` column is allowed
# to be empty when the analyser produced an assertion without any
# concrete tokens (which is itself a soft signal worth flagging).
ASSERTION_TABLE: list[tuple[int, str, str, list[str]]] = [
{{ASSERTION_ROWS}}
]


def _case_id(idx: int, scenario: str) -> str:
    safe = re.sub(r"[^A-Za-z0-9]+", "-", scenario)[:60].strip("-")
    return f"{idx + 1:02d}-{safe or f'case-{idx + 1}'}"


def _assertion_id(row: tuple[int, str, str, list[str]]) -> str:
    aidx, scenario, assertion, _needles = row
    safe_assertion = re.sub(r"[^A-Za-z0-9]+", "-", assertion)[:40].strip("-")
    safe_scenario = re.sub(r"[^A-Za-z0-9]+", "-", scenario)[:30].strip("-")
    return f"a{aidx:03d}-{safe_scenario or 'case'}-{safe_assertion or 'assertion'}"


def _fixture_params() -> list[tuple[int, int, dict[str, Any], dict[str, Any]]]:
    out: list[tuple[int, int, dict[str, Any], dict[str, Any]]] = []
    for ci, case in enumerate(CASES):
        files = ((case.get("fixtures") or {}).get("files")) or []
        for fi, file in enumerate(files):
            out.append((ci, fi, case, file))
    return out


