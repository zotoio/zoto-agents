def test_primitive_metadata_is_well_formed() -> None:
    """Static metadata embedded by the stamper matches the schema."""
    assert re.match(
        r"^(skill|command|agent|hook|rule):[^\s]+$", TARGET_ID
    ), f"target_id {TARGET_ID!r} does not match the analyser schema"
    assert KIND in {"skill", "command", "agent", "hook", "rule"}, (
        f"kind {KIND!r} is not one of the analyser-supported kinds"
    )
    assert re.search(r"\.(md|mdc|json)$", SOURCE_PATH, re.IGNORECASE), (
        f"source_path {SOURCE_PATH!r} must point at .md/.mdc/.json"
    )
    assert re.match(r"^[0-9a-f]{64}$", SOURCE_HASH), (
        f"source_hash {SOURCE_HASH!r} must be a 64-char hex sha256"
    )
    assert ANALYSER_VERSION, "analyser_version must be non-empty"
    assert MODEL_ID, "model_id must be non-empty"
    assert SUMMARY.strip(), "analyser summary must be non-empty"


def test_primitive_source_loads_and_is_non_empty() -> None:
    """Primitive source markdown can be loaded and is non-empty."""
    source = _load_source()
    assert source.strip(), f"primitive source {SOURCE_PATH} is empty"


def test_primitive_frontmatter_parses() -> None:
    """Primitive source frontmatter parses to a dict (may be empty for hooks)."""
    source = _load_source()
    fm = _frontmatter(source)
    assert isinstance(fm, dict), "frontmatter parser must return a dict"
    if KIND in {"skill", "command", "agent", "rule"}:
        assert "name" in fm or "description" in fm, (
            f"{KIND} frontmatter must declare at least one of name/description "
            f"(got keys: {sorted(fm)})"
        )


def test_payload_envelope_is_consistent() -> None:
    """Embedded analyser payload matches the file's stamped metadata."""
    assert PAYLOAD_DICT.get("schema_version") == 1, (
        "analyser payload schema_version must be 1"
    )
    assert PAYLOAD_DICT.get("target_id") == TARGET_ID
    assert PAYLOAD_DICT.get("kind") == KIND
    assert PAYLOAD_DICT.get("source_path") == SOURCE_PATH
    assert PAYLOAD_DICT.get("source_hash") == SOURCE_HASH
    assert PAYLOAD_DICT.get("analyser_version") == ANALYSER_VERSION
    assert PAYLOAD_DICT.get("model_id") == MODEL_ID
    assert isinstance(CASES, list) and len(CASES) > 0, (
        "analyser payload must declare at least one case"
    )


def test_payload_loads_into_dataclass_when_available() -> None:
    """When the LLM types module is present, the payload deserialises."""
    if AnalyserPayload is None:
        pytest.skip("evals/_llm/types.py not available; skipping dataclass coercion")
    cases = [
        AnalyserCase(  # type: ignore[call-arg]
            scenario=str(c.get("scenario") or ""),
            prompt=str(c.get("prompt") or ""),
            assertions=list(c.get("assertions") or []),
        )
        for c in CASES
    ]
    payload = AnalyserPayload(  # type: ignore[call-arg]
        schema_version=int(PAYLOAD_DICT["schema_version"]),
        analyser_version=str(PAYLOAD_DICT["analyser_version"]),
        model_id=str(PAYLOAD_DICT["model_id"]),
        target_id=str(PAYLOAD_DICT["target_id"]),
        kind=str(PAYLOAD_DICT["kind"]),  # type: ignore[arg-type]
        source_path=str(PAYLOAD_DICT["source_path"]),
        source_hash=str(PAYLOAD_DICT["source_hash"]),
        summary=str(PAYLOAD_DICT["summary"]),
        cases=cases,
    )
    assert payload.target_id == TARGET_ID
    assert len(payload.cases) == len(CASES)


