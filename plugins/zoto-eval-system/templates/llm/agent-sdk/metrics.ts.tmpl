/**
 * Soft-metric calculators.
 *
 * These metrics enrich the results.yml and are referenced by the judge skill
 * to identify weak assertions and anomalies.
 */

export interface RawRun {
  prompt: string;
  response: string;
  assertionsMet: number;
  assertionsTotal: number;
  toolCalls: Array<{ tool: string; ok: boolean }>;
  confidenceFromModel?: number | null;
  promptTokens?: number;
  completionTokens?: number;
  startedAt: number;
  endedAt: number;
}

export interface SoftMetrics {
  tokens: number;
  duration_ms: number;
  verbosity: number;
  accuracy: number;
  confidence: number;
}

export function computeMetrics(r: RawRun): SoftMetrics {
  const promptTokens = r.promptTokens ?? approximateTokens(r.prompt);
  const completionTokens = r.completionTokens ?? approximateTokens(r.response);
  const tokens = promptTokens + completionTokens;
  const duration_ms = Math.max(0, r.endedAt - r.startedAt);

  const verbosity = promptTokens === 0 ? 0 : completionTokens / promptTokens;
  const accuracy = r.assertionsTotal === 0 ? 0 : r.assertionsMet / r.assertionsTotal;

  let confidence: number;
  if (typeof r.confidenceFromModel === "number") {
    confidence = clamp01(r.confidenceFromModel);
  } else {
    const toolOkRatio =
      r.toolCalls.length === 0
        ? 0.5
        : r.toolCalls.filter((t) => t.ok).length / r.toolCalls.length;
    confidence = clamp01(0.5 * accuracy + 0.5 * toolOkRatio);
  }

  return {
    tokens,
    duration_ms,
    verbosity: round3(verbosity),
    accuracy: round3(accuracy),
    confidence: round3(confidence),
  };
}

function approximateTokens(text: string): number {
  if (!text) return 0;
  return Math.ceil(text.length / 4);
}

function clamp01(n: number): number {
  if (Number.isNaN(n)) return 0;
  return Math.min(1, Math.max(0, n));
}

function round3(n: number): number {
  return Math.round(n * 1000) / 1000;
}
