// _meta.generated: true
/**
 * Custom jest reporter for the LLM `code` strategy.
 *
 * Stamped at `<host-repo>/evals/llm/_shared/reporters/zoto-llm-reporter.ts`
 * by `plugins/zoto-eval-system/scripts/eval-stamp.ts#stampLlmCodePerPrimitive` (subtask 09) when
 * `llm.codeFramework === "jest"`.
 *
 * Aggregation pattern is identical to the vitest reporter — see
 * `zoto-llm-reporter.vitest.ts.tmpl` for the full description. Both
 * reporters delegate to `aggregateRunFromSidecars(...)` so the YAML
 * output is byte-identical given the same set of sidecars.
 */
import { existsSync, readFileSync } from "node:fs";
import { join, resolve } from "node:path";

import type { AggregatedResult, Reporter, ReporterOnStartOptions } from "@jest/reporters";
import type { Test, TestContext } from "@jest/test-result";

import { aggregateRunFromSidecars } from "../case-runner.js";

const REPO_ROOT = process.env.ZOTO_EVAL_REPO_ROOT
  ? resolve(process.env.ZOTO_EVAL_REPO_ROOT)
  : resolve(process.cwd());
const RUN_DIR_REL = "evals/_runs";

export default class ZotoLlmReporter implements Reporter {
  private startedAt = "";

  onRunStart(_aggregated: AggregatedResult, _options: ReporterOnStartOptions): void {
    this.startedAt = new Date().toISOString();
  }

  onRunComplete(_contexts: Set<TestContext>, _aggregated: AggregatedResult): void {
    const endedAt = new Date().toISOString();
    const runId =
      process.env.ZOTO_EVAL_RUN_ID ?? computeRunId(this.startedAt || endedAt);
    const sidecarDir =
      process.env.ZOTO_EVAL_RUN_SIDECAR_DIR ??
      join(REPO_ROOT, RUN_DIR_REL, runId, "_pending", "llm-cases");
    const dest = join(REPO_ROOT, RUN_DIR_REL, runId, "llm.yml");
    const model = readModelFromConfig() ?? process.env.ZOTO_EVAL_MODEL;

    const doc = aggregateRunFromSidecars({
      runId,
      startedAt: this.startedAt || endedAt,
      endedAt,
      model,
      sidecarDir,
      destPath: dest,
    });
    process.stdout.write(
      `[zoto-llm-reporter] wrote ${dest} (cases=${doc.totals.cases}, passed=${doc.totals.passed}, failed=${doc.totals.failed})\n`,
    );
  }

  onTestStart(_test: Test): void {
    /* no-op — the case-runner emits sidecars from inside each `it(...)` */
  }

  getLastError(): Error | undefined {
    return undefined;
  }
}

export function computeRunId(startedAt: string): string {
  return startedAt
    .replace(/\..*$/, "")
    .replace(/[-:Z]/g, "");
}

function readModelFromConfig(): string | undefined {
  const cfgPath = join(REPO_ROOT, ".zoto", "eval-system", "config.json");
  if (!existsSync(cfgPath)) return undefined;
  try {
    const j = JSON.parse(readFileSync(cfgPath, "utf-8")) as {
      llm?: { model?: { id?: string } };
    };
    return j.llm?.model?.id;
  } catch {
    return undefined;
  }
}
