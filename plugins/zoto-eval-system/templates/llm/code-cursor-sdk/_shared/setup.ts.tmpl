import "dotenv/config";

import { mkdirSync } from "node:fs";
import { join, resolve } from "node:path";

const REPO_ROOT = process.env.ZOTO_EVAL_REPO_ROOT
  ? resolve(process.env.ZOTO_EVAL_REPO_ROOT)
  : resolve(process.cwd());

function computeRunId(): string {
  /* Lex-sortable, filename-safe stamp. Matches the format used by the
   * static reporter (subtask 07) so both backends drop into the same
