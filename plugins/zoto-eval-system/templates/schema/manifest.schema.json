{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zotoio.github.io/zoto-agents/schemas/zoto-eval-system/manifest.schema.json",
  "title": "Zoto Eval System Manifest",
  "description": "Persistent catalogue of discovered primitives and their stamped eval artefacts. Hand-authored scenario files under `evals/scenarios/<name>.test.ts` are intentionally NOT tracked in `targets[].eval_files[]` — scenarios live outside the manifest trail and are excluded from this schema by design. Per-file JSON validation against `eval-file.schema.json` is enforced at runtime by `engine/runner.ts` / `engine/update.ts`, not at manifest-write time.",
  "type": "object",
  "required": ["schema_version", "created_at", "updated_at", "git_ref", "generated_by", "discovery_config", "targets"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "git_ref": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "generated_by": {
      "type": "string",
      "enum": ["zoto-create-evals", "zoto-update-evals"]
    },
    "discovery_config": {
      "type": "object",
      "required": ["discoveryTargets", "skillsRoots", "evalsDir"],
      "additionalProperties": true,
      "description": "Snapshot of the active config at the moment of the last `zoto-create-evals` / `zoto-update-evals` write. The cleanup engine (subtask 03) compares the live config against this snapshot to detect framework/strategy drift without re-reading historical configs. Older manifests without `static`/`llm` snapshot blocks remain backward-compatible; consumers must tolerate missing values.",
      "properties": {
        "discoveryTargets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skillsRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evalsDir": { "type": "string" },
        "additionalAutomation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "static": {
          "type": "object",
          "additionalProperties": true,
          "description": "Snapshot of the active static-backend config at write time.",
          "properties": {
            "framework": {
              "type": "string",
              "enum": ["pytest", "vitest", "jest"]
            }
          }
        },
        "llm": {
          "type": "object",
          "additionalProperties": true,
          "description": "Snapshot of the active LLM-strategy config at write time.",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["code", "declarative"]
            },
            "codeFramework": {
              "type": "string",
              "enum": ["vitest", "jest"]
            }
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "path", "content_hash", "eval_files"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^(skill|command|agent|hook|cli|lib):[^\\s]+$" },
          "kind": { "type": "string", "enum": ["skill", "command", "agent", "hook", "cli", "lib"] },
          "path": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "public_surface": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "frontmatter": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              },
              "exports": { "type": "array", "items": { "type": "string" } },
              "tools": { "type": "array", "items": { "type": "string" } }
            }
          },
          "eval_files": {
            "type": "array",
            "description": "Repo-relative paths to eval artefact files the stamper/updater owns. Non-skill entries MUST end in `.json` after the JSON-first migration; skill entries MUST be `evals/evals.json`. Scenario `.test.ts` files under `evals/scenarios/` are never listed here.",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "kind": { "const": "skill" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "eval_files": {
                  "items": {
                    "type": "string",
                    "pattern": "evals\\.json$",
                    "description": "Skill targets MUST reference `evals/evals.json` per the Cursor Agent Skills spec."
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": { "enum": ["command", "agent", "hook", "cli", "lib"] }
              },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "eval_files": {
                  "items": {
                    "type": "string",
                    "pattern": "\\.json$",
                    "description": "Non-skill LLM eval files MUST use co-located `.json` paths (JSON-first migration)."
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}
