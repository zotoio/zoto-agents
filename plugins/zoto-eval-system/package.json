{
  "name": "@zoto-agents/zoto-eval-system",
  "version": "0.1.0",
  "private": true,
  "description": "Generate, run, and consciously update static (pytest) + LLM (@cursor/sdk) evals when AI primitives change — every proposed change requires user confirmation.",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sqlite3"
    ]
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsx scripts/validate-plugin.ts",
    "install-local": "tsx scripts/install-local.ts",
    "uninstall-local": "tsx scripts/uninstall-local.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "jest": "^30.0.0",
    "js-yaml": "^4.1.1",
    "json-source-map": "^0.6.1",
    "minimatch": "^10.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.4.0",
    "vitest": "^3.1.0"
  }
}
