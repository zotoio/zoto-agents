{
  "name": "zoto-agents",
  "private": true,
  "description": "Monorepo for Cursor plugins by zotoio",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "validate": "pnpm -r validate",
    "validate-template": "node scripts/validate-template.mjs",
    "validate-skills": "node scripts/validate-skills.mjs",
    "eval": "tsx scripts/eval-orchestrate.ts",
    "eval:full": "tsx scripts/eval-orchestrate.ts --full",
    "eval:gc": "tsx scripts/eval-gc.ts --dry-run",
    "eval:gc:apply": "tsx scripts/eval-gc.ts --apply",
    "eval:static": "python3 scripts/test.py",
    "eval:static:pytest": "pytest evals/ -v --tb=short",
    "eval:list": "tsx plugins/zoto-eval-system/engine/runner.ts --list",
    "eval:manual": "python3 scripts/test.py --mode manual",
    "eval:judge": "tsx plugins/zoto-eval-system/engine/runner.ts --judge-only",
    "eval:update": "tsx plugins/zoto-eval-system/engine/update.ts",
    "eval:update:check": "tsx plugins/zoto-eval-system/engine/update.ts --check",
    "eval:compare": "tsx plugins/zoto-eval-system/engine/compare.ts",
    "eval:cleanup-sandboxes": "tsx scripts/eval-cleanup-sandboxes.ts",
    "eval:sandbox-selftest": "tsx evals/_llm/sandbox.selftest.ts",
    "eval:analyse": "tsx scripts/eval-analyse.ts",
    "eval:analyser-parity-check": "tsx scripts/check-analyser-payload-parity.ts",
    "eval:discover": "tsx scripts/eval-discover.ts",
    "eval:stamp": "tsx scripts/eval-stamp.ts",
    "eval:baseline-stamp": "tsx scripts/eval-stamp.ts --baseline-only",
    "eval:cleanup-vendored": "tsx scripts/eval-cleanup-vendored.ts",
    "eval:cleanup-stale": "tsx scripts/eval-cleanup-stale.ts",
    "eval:cleanup-stale:apply": "tsx scripts/eval-cleanup-stale.ts -- --apply",
    "eval:static:vitest": "vitest run --config evals/vitest.config.ts",
    "eval:static:jest": "NODE_OPTIONS=--experimental-vm-modules jest --config evals/jest.config.ts",
    "eval:bootstrap-llm-code": "tsx scripts/bootstrap-llm-code-from-cache.ts",
    "eval:llm": "vitest run --config evals/llm/vitest.config.ts",
    "eval:ensure-host": "tsx scripts/eval-ensure-host.ts"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.12",
    "@jest/globals": "^30.3.0",
    "@jest/reporters": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "ajv": "^8.20.0",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.4"
  },
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "json-source-map": "^0.6.1"
  }
}
