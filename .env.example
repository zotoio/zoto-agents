# Eval system — environment variables.
#
# Copy this file to `.env` (NEVER commit `.env`):
#
#   cp .env.example .env
#
# `.env` is loaded automatically by the LLM eval runner via `dotenv/config`.
# Anything exported in your shell still wins over `.env` (standard dotenv
# precedence: existing process.env > .env file).

# Required for `pnpm run eval:full` and `pnpm run eval:llm`.
# Generate one in Cursor (Settings → API Keys) or via the cloud dashboard.
CURSOR_API_KEY=

# Optional — overrides `config.llm.model.id` for the LLM runner.
# Allowed: composer-2.5 | opus-4.6 | sonnet
# (CLI flag `--model <id>` still wins over this.)
# ZOTO_EVAL_MODEL=composer-2.5

# Optional — overrides the LLM-judge model used by the rubric grader.
# Accepts abstract labels (opus-4.6, sonnet) or concrete API ids
# (claude-opus-4-6, claude-opus-4-7, claude-sonnet-4-6, etc.).
# Abstract labels are mapped via `sdk-bridge#DEFAULT_MODEL_ALIASES`.
# ZOTO_EVAL_JUDGE_MODEL=opus-4.6

# Optional — JSON object mapping abstract labels to concrete API ids.
# Merges over the bridge defaults; useful when the provider renames a
# model and you want a one-line repo-local fix without a code change.
# Example:
#   ZOTO_EVAL_MODEL_ALIASES='{"opus-4.6":"claude-opus-4-7"}'
